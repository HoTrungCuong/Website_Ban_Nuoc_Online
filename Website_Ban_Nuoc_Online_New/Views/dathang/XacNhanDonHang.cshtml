@model Website_Ban_Nuoc_Online.Models.GioHang
@using Website_Ban_Nuoc_Online.Models
@{
    ViewBag.Title = "Xác nhận đơn hàng";
    var user = ViewBag.KhachHang as KhachHang;
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger text-center fw-bold mt-3">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success text-center fw-bold mt-3">@TempData["Success"]</div>
}

<div class="container mt-5">
    <h2 class="text-center text-success mb-4 fw-bold">XÁC NHẬN ĐƠN HÀNG</h2>

    <!-- THÔNG TIN KHÁCH HÀNG -->
    <div class="card shadow-sm p-4 mb-4">
        <h4 class="text-primary mb-3">Thông tin người nhận</h4>
        <p><strong>Họ tên:</strong> @user.HoTen</p>
        <p><strong>Địa chỉ:</strong> @user.DiaChi</p>
        <p><strong>Số điện thoại:</strong> @user.SDT</p>
    </div>

    <!-- DANH SÁCH SẢN PHẨM -->
    <div class="card shadow-sm p-4 mb-4">
        <h4 class="text-primary mb-3">Danh sách sản phẩm</h4>
        <table class="table table-bordered align-middle text-center">
            <thead class="table-success">
                <tr>
                    <th>Tên món</th>
                    <th>Đơn giá</th>
                    <th>Số lượng</th>
                    <th>Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.lst)
                {
                    <tr>
                        <td>@item.sTenMon</td>
                        <td>@String.Format("{0:N0} VNĐ", item.dDonGia)</td>
                        <td>@item.iSoLuong</td>
                        <td>@String.Format("{0:N0} VNĐ", item.ThanhTien)</td>
                    </tr>
                }
            </tbody>
        </table>

        @* ========== TÍNH TỔNG ========== *@
        @{
            decimal PHI_VAN_CHUYEN = 15000m; // phí cố định
            decimal tongHang = Convert.ToDecimal(Model.TongThanhTien());
            decimal phanTram = Convert.ToDecimal(Model.PhanTramGiam);
            decimal soTienGiam = 0m;

            if (phanTram > 0)
            {
                soTienGiam = tongHang * phanTram / 100m;
            }

            decimal tongSauGiam = tongHang - soTienGiam;
            decimal tongCuoi = tongSauGiam + PHI_VAN_CHUYEN;
        }

        <div class="text-end mt-3">
            <p><strong>Tổng tiền hàng:</strong> @String.Format("{0:N0} VNĐ", tongHang)</p>

            @if (phanTram > 0)
            {
                <p class="text-success"><strong>Mã giảm giá:</strong> @Model.TenKM (@Model.PhanTramGiam%)</p>
                <p class="text-danger"><strong>Số tiền giảm:</strong> @String.Format("{0:N0} VNĐ", soTienGiam)</p>
            }

            <p><strong>Phí vận chuyển:</strong> @String.Format("{0:N0} VNĐ", PHI_VAN_CHUYEN)</p>

            <h4 class="text-danger fw-bold mt-3">
                Tổng thanh toán (bao gồm phí vận chuyển):
                @String.Format("{0:N0} VNĐ", tongCuoi)
            </h4>
        </div>
    </div>

    @* ========== FORM XÁC NHẬN + CHỌN PHƯƠNG THỨC THANH TOÁN ========== *@
    @using (Html.BeginForm("ThanhToan", "DatHang", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        @* nếu cần truyền tổng tiền / phí về server thì có thể thêm hidden *@
        <input type="hidden" name="TongTienHang" value="@tongHang" />
        <input type="hidden" name="PhiVanChuyen" value="@PHI_VAN_CHUYEN" />
        <input type="hidden" name="TongThanhToan" value="@tongCuoi" />

        <div class="card shadow-sm p-4 mb-4">
            <h4 class="text-primary mb-3">Phương thức thanh toán</h4>

            <div class="form-check">
                <input class="form-check-input" type="radio"
                       name="PhuongThucTT" id="pt-momo" value="MoMo" checked />
                <label class="form-check-label" for="pt-momo">
                    Thanh toán qua ví MoMo (hoặc QR ví điện tử)
                </label>
            </div>

            <div class="form-check mt-2">
                <input class="form-check-input" type="radio"
                       name="PhuongThucTT" id="pt-banking" value="Banking" />
                <label class="form-check-label" for="pt-banking">
                    Chuyển khoản ngân hàng
                </label>
            </div>

            <div class="form-check mt-2">
                <input class="form-check-input" type="radio"
                       name="PhuongThucTT" id="pt-cod" value="COD" />
                <label class="form-check-label" for="pt-cod">
                    Thanh toán khi nhận hàng (COD)
                </label>
            </div>

            <div class="mt-3 text-muted small">
                <p>Phí vận chuyển: <strong>@String.Format("{0:N0} VNĐ", PHI_VAN_CHUYEN)</strong>.</p>
                <p>Với MoMo / Banking, hệ thống sẽ hiển thị thông tin chuyển khoản ở bước tiếp theo.</p>
            </div>
        </div>

        <!-- NÚT XÁC NHẬN -->
        <div class="text-end mt-4">
            <a href="@Url.Action("XemGioHang", "DatHang")" class="btn btn-outline-secondary">
                ← Quay lại giỏ hàng
            </a>
            <button type="submit" class="btn btn-success ms-2 px-4">
                Xác nhận đặt hàng
            </button>
        </div>
    }
</div>
