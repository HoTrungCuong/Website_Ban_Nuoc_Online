
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<section class="checkout-section py-5" style="background-color: #fff7f1;">
    <div class="container py-5">
        <div class="text-center" style="margin: 2px 0 40px;">
            <h2 class="about-heading" id="about-us">About Us</h2>
        </div>
        <!-- 1. Story -->

        <h2 class="section-title text-center">Hành Trình Từ Hạt Cà Phê Đến Nụ Cười</h2>
        <div class="row g-4 align-items-center">
            <div class="col-md-6">
                <img src="~/Content/Images/nongtrai.jpg" class="img-fluid rounded shadow-sm" alt="Nông trại cà phê Đắk Lắk">
            </div>
            <div class="col-md-6">
                <div class="row gy-4">
                    <div class="col-12">
                        <h3 class="section-subtitle">Khởi nguồn ý tưởng</h3>
                        <p>"Từ một chuyến thăm nông trại cà phê Đắk Lắk, chúng tôi nhận ra mỗi hạt cà phê mang theo cả câu chuyện và trái tim người nông dân."</p>
                    </div>
                    <div class="col-12">
                        <h3 class="section-subtitle">Động lực thành lập</h3>
                        <p>"Muốn lan tỏa hương vị nguyên bản, kết nối người yêu cà phê với văn hoá Việt."</p>
                    </div>
                    <div class="col-12">
                        <h3 class="section-subtitle">Ý nghĩa tên gọi</h3>
                        <p>"'Smile Coffee' – tách cà phê của chúng tôi không chỉ thỏa cơn khát, mà còn khơi gợi nụ cười."</p>
                    </div>
                </div>
            </div>
        </div>


        <div style="margin-bottom: 55px;margin-top: 55px;">
            <h2 class="section-title text-center">Cam Kết Từ Trái Tim</h2>
            <div class="commit-grid">
                <div class="commit-card">
                    <div class="icon"><i class="bi bi-stars"></i></div>
                    <h6>Phục vụ 5 sao</h6>
                    <p>Luôn nở nụ cười, lắng nghe yêu cầu của khách.</p>
                </div>
                <div class="commit-card">
                    <div class="icon"><i class="bi bi-truck"></i></div>
                    <h6>Giao nhanh 30'</h6>
                    <p>Đảm bảo bánh ngọt, nước uống vẫn ngon sau khi giao.</p>
                </div>
                <div class="commit-card">
                    <div class="icon"><i class="bi bi-gift"></i></div>
                    <h6>Ưu đãi thường xuyên</h6>
                    <p>Thẻ thành viên, combo sáng, thử vị miễn phí.</p>
                </div>


            </div>
        </div>
        <!-- 22. Team -->
        <div class="section-block">
            <h2 class="section-title text-center">Gặp Gỡ Đội Ngũ Smile Coffee</h2>
            <div class="team-grid">
                <!-- Repeat for each member -->
                <div class="team-card">
                    <img src="~/Content/Images/avatar1.jpg" alt="Đặng Tuấn Anh">
                    <h5>Hồ Trung Cương</h5>
                    <small>Nhà hoạch định chiến lược</small>
                    <p>Định hướng phát triển, kế hoạch tài chính và quyết định then chốt.</p>
                    <p>Lan tỏa niềm đam mê cà phê và giá trị cốt lõi.</p>
                </div>
                <div class="team-card">
                    <img src="~/Content/Images/avatar2.jpg" alt="Trần Quang Thành">
                    <h5>Đặng Nguyễn Minh Đăng</h5>
                    <small>Quản lý vận hành</small>
                    <p>Giám sát nguyên liệu, đào tạo nhân viên, đảm bảo chất lượng.</p>
                    <p>Xây dựng hình ảnh, chiến lược quảng bá, kết nối cộng đồng.</p>
                </div>
            </div>
        </div>
        <!-- 5. Commitments -->

    </div>
</section>


