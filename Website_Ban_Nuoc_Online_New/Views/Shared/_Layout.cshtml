<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="stylesheet" href="~/Content/style.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <style>
        body {
        }

        .card-title {
            font-size: 15px;
        }

        .btn {
            background-color: #7b4a52;
            color: aliceblue;
        }

            .btn:hover {
                background-color: #5a363f;
                color: white;
            }

        .sidebar {
            border-right: 1px solid #dee2e6;
            border-radius: 10px;
            box-shadow: 0 8px 16px rgba(0, 0, 0, .12);
            overflow: hidden;
        }

            .sidebar h4 {
                padding: 15px;
                background: #ffd800;
                color: #7b4a52;
                margin: 0;
            }

            .sidebar a {
                display: block;
                padding: 10px;
                color: #7b4a52;
                text-decoration: none;
            }

                .sidebar a:hover, .sidebar a.active {
                    background: #e9ecef;
                    font-weight: bold;
                }

        /* Thêm CSS cho menu active (tuỳ chỉnh thêm nếu cần) */
        .menu-links.bg-warning a.nav-link.active {
            background-color: #7b4a52;
            color: white !important;
            font-weight: bold;
            border-radius: 4px;
        }

        .card-img-top {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform .3s ease;
        }

        .card {
            overflow: hidden;
        }

        .card-img-top:hover {
            transform: scale(1.2);
        }

        .thumb {
            aspect-ratio: 4 / 3;
            overflow: hidden;
            background: #eee;
            height: 150px;
        }

        .btn-custom {
            padding: 10px 12px;
            border-radius: 10px;
        }

        .btn-search {
            width: 100px;
        }

        .lang-btn {
            position: relative;
            display: inline-block;
        }


        .dropdown {
            display: none;
            position: absolute;
            top: 100%;
            left: 0;
            background-color: white;
            border: 1px solid #ccc;
            border-radius: 6px;
            margin-top: 5px;
        }

            .dropdown p {
                margin: 0;
                padding: 8px 12px;
                cursor: pointer;
            }

                .dropdown p:hover {
                    background-color: #f1f1f1;
                }

        .lang-btn:hover .dropdown {
            display: block;
        }

        .admin-strip {
            background: #7b4a52;
            color: #fff;
            text-align: center;
            padding: 10px 12px;
            border-radius: 8px;
            font-weight: 600;
            letter-spacing: .2px;
            margin-top: 16px;
            display: block;
            text-decoration: none;
        }

            .admin-strip:hover {
                background: #5a363f;
                color: #fff;
            }
    </style>
    <style>
        /* Đảm bảo backdrop và modal nằm trên tất cả phần tử khác */
        .modal-backdrop.show {
            z-index: 20000 !important;
        }

        .modal {
            z-index: 20001 !important;
        }
    </style>

</head>

<body>
    <div>
        <div class="top-bar d-flex justify-content-between align-items-center px-4 py-2" style="height:70px">
            <div>GIỜ MỞ CỬA : 08:00 AM - 9:00 PM</div>
            <div>ĐỊA CHỈ QUÁN: 140 LÊ TRỌNG TẤN, QUẬN TÂN PHÚ, TP.HCM</div>
        </div>
        <div class="menu-container text-center">
            <ul class="nav justify-content-center menu-links">
                <li class="nav-item">
                    <img src="~/Content/Images/logo.jpg" class="logo-large" alt="Smile Coffee">
                </li>
            </ul>

            <ul class="nav justify-content-center menu-links bg-warning">
                @{
                    // Lấy Controller và Action hiện tại để so sánh
                    var currentController = ViewContext.RouteData.Values["Controller"].ToString();
                    var currentAction = ViewContext.RouteData.Values["Action"].ToString();

                    // SỬ DỤNG LOCAL FUNCTION (C#) để định nghĩa hàm với tham số mặc định, khắc phục lỗi Func<>
                    string GetActiveClass(string controller, string action = "Index")
                    {
                        // Kiểm tra không phân biệt chữ hoa, chữ thường
                        if (currentController.Equals(controller, StringComparison.OrdinalIgnoreCase) && currentAction.Equals(action, StringComparison.OrdinalIgnoreCase))
                        {
                            return " active";
                        }
                        return "";
                    }
                }

                <li class="nav-item">
                    <a class="nav-link@(GetActiveClass("Home"))" href="/Home/Index">TRANG CHỦ</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link@(GetActiveClass("GioiThieu"))" href="/GioiThieu/Index">GIỚI THIỆU</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link@(GetActiveClass("Mons"))" href="/Mons/Index">THỰC ĐƠN</a>
                </li>
                <li class="nav-item position-relative">
                    <a href="@Url.Action("XemGioHang","DatHang")" class="nav-link@(GetActiveClass("DatHang", "XemGioHang"))">
                        GIỎ HÀNG (@(Session["SoLuongGioHang"] ?? 0))
                    </a>
                </li>

                @if (Session["IsAdmin"] != null && (bool)Session["IsAdmin"] == true)
                {
                    <li class="nav-item">
                        <a class="nav-link text-danger fw-bold@(GetActiveClass("QuanLy"))" href="/QuanLy/Index">QUẢN TRỊ</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/Home/Index" data-bs-toggle="modal" data-bs-target="#logoutModal">ĐĂNG XUẤT</a>
                    </li>
                }
                else if (Session["User"] != null)
                {
                    <li class="nav-item">
                        <a class="nav-link@(GetActiveClass("User", "LichSuMuaHang"))" href="@Url.Action("LichSuMuaHang","User")">LỊCH SỬ MUA HÀNG</a>
                    </li>
                    <li class="nav-item"><a class="nav-link" data-bs-toggle="modal" data-bs-target="#logoutModal">ĐĂNG XUẤT</a></li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link@(GetActiveClass("User", "Login"))" href="@Url.Action("Login","User")">ĐĂNG NHẬP</a>
                    </li>
                }
            </ul>
        </div>
    </div>

    <div class="page-wrapper">
        @RenderBody()
    </div>

    <footer class="footer-section py-5" style="background: #fff; color: #7b4a52;">
        <div class="container">
            <div class="top-bar d-flex justify-content-between align-items-center px-4 py-2" style="height:40px"></div>
            <br />
            <div class="row align-items-start">

                <div class="col-lg-3 col-md-6 mb-4 text-center text-lg-start">
                    <img src="~/Content/Images/logo.jpg" alt="Smile Coffee" style="width:140px;">
                    <p class="mt-3" style="font-style: italic;">"Nụ cười khởi nguồn từ ly cà phê đậm đà"</p>
                </div>

                <div class="col-lg-3 col-md-6 mb-4">
                    <h5 class="fw-bold" style="border-left: 4px solid #7b4a52; padding-left: 8px;">Liên kết nhanh</h5>
                    <ul class="list-unstyled mt-3">
                        <li><a href="/Home/Index" class="footer-link">Trang Chủ</a></li>
                        <li><a href="/Mons/Index" class="footer-link">Thực Đơn</a></li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6 mb-4">
                    <h5 class="fw-bold" style="border-left: 4px solid #7b4a52; padding-left: 8px;">Liên hệ</h5>
                    <p class="mt-3 mb-1">140 Lê Trọng Tấn, Q. Tân Phú, TP.HCM</p>
                    <p class="mb-1">Hotline: <a href="tel:0123456789" class="footer-link">0123 456 789</a></p>
                    <p class="mb-1">Email: <a href="mailto:info@smilecoffee.com" class="footer-link">info@smilecoffee.com</a></p>
                </div>

                <div class="col-lg-3 col-md-6 mb-4 text-center text-lg-end">
                    <div class="d-flex gap-3 justify-content-center justify-content-lg-end">
                        <a href="#" class="social-circle"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="social-circle"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="social-circle"><i class="fab fa-twitter"></i></a>
                    </div>

                    <a class="admin-strip" href="/Admin/Auth">
                        Đăng ký làm người quản lý
                    </a>

                </div>
            </div>

            <div class="text-center pt-3 mt-3 border-top" style="border-color: #c7b4b8;">
                © 2025 Smile Coffee.
            </div>
        </div>
    </footer>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/Scripts/slider.js"></script>
    @* Form logout POST ẩn *@
    @using (Html.BeginForm("Logout", "User", FormMethod.Post, new { id = "logoutForm", style = "display:none" }))
    {
        @Html.AntiForgeryToken()
    }

    @* Modal – bảng xác nhận đăng xuất *@
    <div class="modal fade" id="logoutModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius: 12px;">
                <div class="modal-header">
                    <h5 class="modal-title">Xác nhận đăng xuất</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">Bạn có chắc muốn đăng xuất?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Không</button>
                    <button type="button" class="btn btn-danger" onclick="document.getElementById('logoutForm').submit()">Có</button>
                </div>
            </div>
        </div>
    </div>
    @RenderSection("scripts", required: false)
</body>
</html>