@model Website_Ban_Nuoc_Online.Models.Mon

@{
    ViewBag.Title = "Details";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-5">
            <div class="card shadow-sm border-0">
                <img src="~/Content/images/@Model.HinhAnh" class="card-img-top rounded" alt="@Model.TenMon">
            </div>
        </div>

        <div class="col-md-7">
            <h2 class="mb-3 text-primary">@Model.TenMon</h2>
            <h4 class="text-danger fw-bold">@String.Format("{0:N0} VNĐ", Model.GiaBan)</h4>

            <p class="mt-3" style="line-height: 1.8; font-size: 1.1rem; text-align: justify;">
                @Model.MoTa
            </p>

            @using (Html.BeginForm("ThemMatHang", "DatHang", FormMethod.Post))
            {
                <input type="hidden" name="msp" value="@Model.MaMon" />

                <div class="d-flex align-items-center mt-3">
                    <label class="me-2 fw-semibold">Số lượng:</label>
                    <input type="number" name="soluong" value="1" min="1" class="form-control w-auto" style="width: 90px;" />
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-lg px-4">
                        🛒 Thêm vào giỏ
                    </button>
                    <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary btn-lg px-4 ms-2">
                        Quay lại
                    </a>
                </div>
            }
        </div>
    </div>
    @if (ViewBag.SanPhamLienQuan != null)
    {
        var spLienQuan = ViewBag.SanPhamLienQuan as List<Website_Ban_Nuoc_Online.Models.Mon>;

        if (spLienQuan != null && spLienQuan.Any())
        {
            <div style="margin-top:40px;">
                <h4 style="margin-bottom:20px;">Sản phẩm liên quan</h4>
                <div class="row">
                    @foreach (var sp in spLienQuan)
                    {
                        <div class="col-md-3 col-sm-6" style="margin-bottom:20px;">
                            <div class="thumbnail" style="height:100%;">
                                <img src="~/Content/Images/@sp.HinhAnh" class="img-responsive" width:"100%" height="200" alt="@sp.TenMon" />

                                <div class="caption text-center">
                                    <h5>@sp.TenMon</h5>
                                    <p style="color:red; font-weight:bold;">
                                        @String.Format("{0:N0} VNĐ", Model.GiaBan)
                                    </p>
                                    <p>
                                        <a href="@Url.Action("Details","Mons", new { id = sp.MaMon })"
                                           class="btn btn-sm">
                                            Xem chi tiết
                                        </a>
                                    </p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>