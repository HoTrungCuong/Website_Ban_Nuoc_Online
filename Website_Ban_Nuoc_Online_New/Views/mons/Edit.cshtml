@model Website_Ban_Nuoc_Online.Models.Mon

@{
    ViewBag.Title = "Cập nhật món";
    Layout = "~/Views/Shared/_Layout_QL.cshtml"; 
}

<div class="container mt-5">
    <div class="card shadow-sm">
        <div class="card-header text-white" style="background-color:#7b4a52;">
            <h4 class="mb-0">Cập nhật món</h4>
        </div>
        <div class="card-body">
            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })
                @Html.HiddenFor(model => model.MaMon)

                <div class="mb-3">
                    @Html.LabelFor(m => m.TenMon, "Tên món", new { @class = "form-label fw-bold" })
                    @Html.EditorFor(m => m.TenMon, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(m => m.TenMon, "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.GiaBan, "Giá bán", new { @class = "form-label fw-bold" })
                    @Html.EditorFor(m => m.GiaBan, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(m => m.GiaBan, "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.MoTa, "Mô tả", new { @class = "form-label fw-bold" })
                    @Html.EditorFor(m => m.MoTa, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(m => m.MoTa, "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.HinhAnh, "Hình ảnh (tên file)", new { @class = "form-label fw-bold" })
                    @Html.EditorFor(m => m.HinhAnh, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(m => m.HinhAnh, "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.MaLoai, "Loại món", new { @class = "form-label fw-bold" })
                    @Html.DropDownList("MaLoai", null, "Chọn loại", new { @class = "form-select" })
                    @Html.ValidationMessageFor(m => m.MaLoai, "", new { @class = "text-danger" })
                </div>

                <div class="d-flex justify-content-between">
                    <input type="submit" value="Lưu thay đổi" class="btn btn-success" />
                    @Html.ActionLink("Quay lại danh sách", "SanPham", "QuanLy", null, new { @class = "btn btn-secondary" })
                </div>
            }
        </div>
    </div>
</div>
