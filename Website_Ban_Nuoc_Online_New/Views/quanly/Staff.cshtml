@model IEnumerable<Website_Ban_Nuoc_Online.Models.NhanVien>

@{
    ViewBag.Title = "Staff";
    Layout = "~/Views/Shared/_Layout_QL.cshtml";
    int pending = ViewBag.PendingOrdersCount ?? 0;
}

<h2>Thông tin nhân viên giao hàng</h2>

<div class="mb-3 d-flex align-items-center">
    <!-- Nút/chuyển trang (thẻ a) với badge -->
    <a class="btn btn-primary me-2 position-relative" href="@Url.Action("NhanDon", "QuanLy")">
        Nhận đơn từ khách hàng
        @if (pending > 0)
        {
            <span class="badge bg-danger position-absolute" style="top:-8px; right:-8px">@pending</span>
        }
    </a>

    <a class="btn btn-secondary" href="@Url.Action("NhanTinhTrang", "QuanLy")">
        Nhận tình trạng đơn từ shipper
    </a>
</div>

<hr />

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">Không có nhân viên trong hệ thống.</div>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>STT</th>
                <th>Họ tên</th>
                <th>Giới tính</th>
                <th>Ngày sinh</th>
            </tr>
        </thead>
        <tbody>
            @{
                int i = 1;
            }
            @foreach (var nv in Model)
            {
                <tr>
                    <td>@i</td>
                    <td>@(nv.HoTen ?? "-")</td>
                    <td>@(nv.GioiTinh ?? "-")</td>
                    <td>@(nv.NgaySinh.HasValue ? nv.NgaySinh.Value.ToString("dd/MM/yyyy") : "-")</td>
                </tr>
                i++;
            }
        </tbody>
    </table>
}
