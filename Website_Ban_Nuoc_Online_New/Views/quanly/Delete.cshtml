@model Website_Ban_Nuoc_Online.Models.Mon

@{
    ViewBag.Title = "Xóa món";
    Layout = "~/Views/Shared/_Layout_QL.cshtml";
}

<div class="container mt-5">
    <div class="card shadow-sm border-danger">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">Xác nhận xóa món</h4>
        </div>
        <div class="card-body">
            <p class="fw-bold text-danger">Bạn có chắc chắn muốn xóa món này không?</p>

            <div class="row">
                <div class="col-md-4">
                    <img src="@Url.Content("~/Content/Images/" + Model.HinhAnh)"
                         class="img-fluid rounded mb-3"
                         alt="Hình món" style="object-fit:cover; width:100%; height:200px;" />
                </div>
                <div class="col-md-8">
                    <dl class="row">
                        <dt class="col-sm-4">Tên món:</dt>
                        <dd class="col-sm-8">@Model.TenMon</dd>

                        <dt class="col-sm-4">Giá bán:</dt>
                        <dd class="col-sm-8">(@Model.GiaBan)đ</dd>
                        <dt class="col-sm-4">Mô tả:</dt>
                        <dd class="col-sm-8">@Model.MoTa</dd>

                        <dt class="col-sm-4">Loại món:</dt>
                        <dd class="col-sm-8">@Model.Loai.TenLoai</dd>
                    </dl>
                </div>
            </div>

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()
                <div class="mt-3 d-flex gap-2">
                    <input type="submit" value="Xóa" class="btn btn-danger" />
                    @Html.ActionLink("Quay lại danh sách", "SanPham", null, new { @class = "btn btn-secondary" })
                </div>
            }
        </div>
    </div>
</div>
