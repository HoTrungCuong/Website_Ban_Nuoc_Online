@{
    ViewBag.Title = "Đổi mật khẩu Admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="d-flex justify-content-center align-items-start py-5" style="min-height:100vh;background:#f8f0e6;">
    <div class="bg-white p-4 rounded-4 shadow-sm" style="width:460px;">
        <h3 class="text-center mb-3">Đổi mật khẩu mới - Admin</h3>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        @using (Html.BeginForm("DoiMatKhau", "Admin", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <input type="hidden" name="Username" value="@ViewBag.Username" />

            <div class="mb-3">
                <label class="form-label">Mật khẩu mới</label>
                <input type="password" name="MatKhauMoi" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Xác nhận mật khẩu</label>
                <input type="password" name="XacNhanMatKhau" class="form-control" required />
            </div>

            <button type="submit" class="btn btn-success w-100">Đổi mật khẩu</button>
        }

        <div class="text-center mt-3">
            <a href="@Url.Action("Auth", "Admin")">Quay lại đăng nhập</a>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
