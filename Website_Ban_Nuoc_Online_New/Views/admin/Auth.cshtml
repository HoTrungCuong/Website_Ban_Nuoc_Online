@{
    ViewBag.Title = "Auth";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Lấy cờ để xác định tab active (server-side)
    bool showRegisterServer = ViewBag.ShowRegister == true;
    bool showLoginAfterRedirect = (TempData["ShowLogin"] != null && (bool)TempData["ShowLogin"]);
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="d-flex justify-content-center align-items-start py-5" style="min-height:100vh;background:#f8f0e6;">
    <div class="bg-white p-4 rounded-4 shadow-sm" style="width:460px;">
        @* Chỉ hiển thị thông báo thành công chung (ví dụ: đăng ký thành công / đăng xuất) *@
        @if (TempData["ThongBao"] != null)
        {
            <div class="alert alert-success text-center fw-bold">@TempData["ThongBao"]</div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success text-center fw-bold">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger text-center fw-bold">@TempData["Error"]</div>
        }
        <!-- Tabs -->
        <ul class="nav nav-tabs border-0 mb-4" id="authTabs" role="tablist">
            <li class="nav-item w-50" role="presentation">
                @{
                    var loginBtnClass = showRegisterServer ? "nav-link w-100 fw-bold text-uppercase" : "nav-link active w-100 fw-bold text-uppercase";
                }
                <button class="@loginBtnClass" id="admin-login-tab" data-bs-toggle="tab" data-bs-target="#admin-login" type="button" role="tab" aria-controls="admin-login" aria-selected="@(showRegisterServer ? "false" : "true")">Đăng nhập</button>
            </li>
            <li class="nav-item w-50" role="presentation">
                @{
                    var registerBtnClass = showRegisterServer ? "nav-link active w-100 fw-bold text-uppercase" : "nav-link w-100 fw-bold text-uppercase";
                }
                <button class="@registerBtnClass" id="admin-register-tab" data-bs-toggle="tab" data-bs-target="#admin-register" type="button" role="tab" aria-controls="admin-register" aria-selected="@(showRegisterServer ? "true" : "false")">Đăng ký</button>
            </li>
        </ul>

        <div class="tab-content">
            <!-- LOGIN -->
            @{
                var loginPaneClass = showRegisterServer ? "tab-pane fade" : "tab-pane fade show active";
                var registerPaneClass = showRegisterServer ? "tab-pane fade show active" : "tab-pane fade";
                // Nếu redirect sau đăng ký thành công, bật login pane
                if (showLoginAfterRedirect) { loginPaneClass = "tab-pane fade show active"; registerPaneClass = "tab-pane fade"; }
            }

            <div class="@loginPaneClass" id="admin-login" role="tabpanel" aria-labelledby="admin-login-tab">
                @using (Html.BeginForm("Login", "Admin", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="fw-bold text-danger">USERNAME</label>
                        <input type="text" name="Username" class="form-control" placeholder="Nhập username" value="@(Request.Form["Username"] ?? "")" />
                        @Html.ValidationMessage("Username", "", new { @class = "text-danger fw-bold" })
                    </div>
                    <div class="mb-3">
                        <label class="fw-bold text-danger">MẬT KHẨU</label>
                        <input type="password" name="Password" class="form-control" placeholder="Nhập mật khẩu" />
                        @Html.ValidationMessage("Password", "", new { @class = "text-danger fw-bold" })
                    </div>
                    <div class="text-end mt-1 mb-2">
                        <a href="@Url.Action("QuenMatKhau", "Admin")" class="small" style="color:red">Quên mật khẩu?</a>
                    </div>
                    <button type="submit" class="btn w-100 text-white fw-bold" style="background:#7b4a52;">ĐĂNG NHẬP</button>
                }
            </div>

            <!-- REGISTER -->
            <div class="@registerPaneClass" id="admin-register" role="tabpanel" aria-labelledby="admin-register-tab">
                @using (Html.BeginForm("Register", "Admin", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <input type="text" name="Username" class="form-control" value="@Request.Form["Username"]" placeholder="Tên đăng nhập (duy nhất)" />
                        @Html.ValidationMessage("Username", "", new { @class = "text-danger fw-bold" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Họ tên</label>
                        <input type="text" name="FullName" class="form-control" value="@Request.Form["FullName"]" placeholder="Nhập họ tên đầy đủ" />
                        @Html.ValidationMessage("FullName", "", new { @class = "text-danger fw-bold" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Mật khẩu</label>
                        <input type="password" name="Password" class="form-control" placeholder="Tối thiểu 6 ký tự (gồm chữ và số)" />
                        @Html.ValidationMessage("Password", "", new { @class = "text-danger fw-bold" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Xác nhận mật khẩu</label>
                        <input type="password" name="ConfirmPassword" class="form-control" placeholder="Nhập lại mật khẩu" />
                        @Html.ValidationMessage("ConfirmPassword", "", new { @class = "text-danger fw-bold" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="Email" class="form-control" value="@Request.Form["Email"]" placeholder="Ví dụ: admin@smilecoffee.com" />
                        @Html.ValidationMessage("Email", "", new { @class = "text-danger fw-bold" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Số điện thoại</label>
                        <input type="text" name="Phone" class="form-control" value="@Request.Form["Phone"]" placeholder="VD: 090xxxxxxx" />
                        @Html.ValidationMessage("Phone", "", new { @class = "text-danger fw-bold" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Căn cước công dân</label>
                        <input type="text" name="CCCD" class="form-control" value="@Request.Form["CCCD"]" placeholder="12 số CCCD" />
                        @Html.ValidationMessage("CCCD", "", new { @class = "text-danger fw-bold" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Ngày sinh</label>
                        <input type="text" name="Date" class="form-control" value="@Request.Form["Date"]" placeholder="xx/xx/xxxx" />
                        @Html.ValidationMessage("Date", "", new { @class = "text-danger fw-bold" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Giới tính</label>
                        <select name="Gender" class="form-select">
                            <option value="">-- Chọn giới tính --</option>
                            <option value="Nam" @(Request.Form["Gender"] == "Nam" ? "selected" : "")>Nam</option>
                            <option value="Nữ" @(Request.Form["Gender"] == "Nữ" ? "selected" : "")>Nữ</option>
                            <option value="Khác" @(Request.Form["Gender"] == "Khác" ? "selected" : "")>Khác</option>
                        </select>
                        @Html.ValidationMessage("Gender", "", new { @class = "text-danger fw-bold" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Địa chỉ</label>
                        <input type="text" name="Address" class="form-control" value="@Request.Form["Address"]" placeholder="Địa chỉ liên hệ" />
                        @Html.ValidationMessage("Address", "", new { @class = "text-danger fw-bold" })
                    </div>

                    <button type="submit" class="btn w-100 text-white fw-bold" style="background-color: #7b4a52">ĐĂNG KÝ LÀM NGƯỜI QUẢN LÝ</button>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .nav-tabs .nav-link {
        background: #d4ab89;
        color: #fff;
        border-radius: 8px 8px 0 0;
        border: none;
    }

        .nav-tabs .nav-link.active {
            background: #6b4835;
            color: #fff;
        }

    /* make validation messages slightly smaller so layout không to */
    .text-danger.fw-bold {
        font-size: 0.9rem;
        margin-top: 4px;
        display: block;
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

@* fallback JS: nếu server-side không set gì, vẫn cố gắng bật tab phù hợp (không cần thiết nhưng giữ phòng trường hợp) *@
<script>
    document.addEventListener("DOMContentLoaded", function () {
        try {
            var loginTabEl = document.querySelector('#admin-login-tab');
            var registerTabEl = document.querySelector('#admin-register-tab');

            // Server side đã xử lý active class; JS chỉ dùng khi cần force after redirect
            var showRegister = @((showRegisterServer) ? "true" : "false");
            var showLoginTemp = @((showLoginAfterRedirect) ? "true" : "false");

            if (showRegister === "true" && registerTabEl) {
                var tab = new bootstrap.Tab(registerTabEl);
                tab.show();
            } else if (showLoginTemp === "true" && loginTabEl) {
                var tab = new bootstrap.Tab(loginTabEl);
                tab.show();
            }
        } catch (e) { /* ignore */ }
    });
</script>
